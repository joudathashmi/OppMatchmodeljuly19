def gpt_decide_batch(client: OpenAI, opp_context: dict, candidates: List[dict]) -> Dict[str, dict]:
    payload = {
        "opportunity": opp_context,
        "candidates": candidates,
        "instruction": (
            "For EACH candidate, produce the full JSON object defined in the system prompt. "
            "Return exactly: {\"results\": [...]}. Required for BOTH Yes and No: every "
            "narrative field specific and named, investment-memo tone, no generic filler."
        ),
    }
    parsed = call_json(client, DECISION_MODEL, DECISION_SYSTEM_PROMPT, payload)
    return {str(r.get("candidate_id", "")).strip(): r for r in parsed.get("results", [])
            if str(r.get("candidate_id", "")).strip()}


def safe_decision(r: dict, fallback_cid: str) -> dict:
    decision = str(r.get("ai_decision", "No")).strip().title()
    if decision not in {"Yes", "No"}:
        decision = "No"

    try:
        match_value = int(r.get("match_value", 0))
    except Exception:
        match_value = 0
    match_value = max(0, min(100, match_value))

    confidence = str(r.get("match_confidence", "Low")).strip().title()
    if confidence not in {"Low", "Medium", "High"}:
        confidence = "Low"

    plan = to_list(r.get("suggested_plan"))[:3]
    while len(plan) < 3:
        plan.append("")

    reasons = to_list(r.get("match_reason"))[:3]
    while len(reasons) < 3:
        reasons.append("")

    return {
        "candidate_id":     str(r.get("candidate_id", fallback_cid)).strip(),
        "ai_decision":      decision,
        "match_value":      match_value,
        "match_confidence": confidence,
        "ai_explanation":   safe_str(r.get("ai_explanation")),
        "ai_insight":       safe_str(r.get("ai_insight")),
        "suggested_plan":   plan,
        "match_reason":     reasons,
    }



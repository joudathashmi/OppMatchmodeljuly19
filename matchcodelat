def main():
    api_key = os.getenv("OPENAI_API_KEY", "")
    if not api_key:
        raise RuntimeError("OPENAI_API_KEY is required.")
    client = OpenAI(api_key=api_key)

    company_file = find_first_existing(COMPANY_FILE_CANDIDATES)
    opp_file     = find_first_existing(OPPORTUNITY_FILE_CANDIDATES)
    print(f"Company file    : {company_file}")
    print(f"Opportunity file: {opp_file}")

    companies     = normalize_company_cols(pd.read_excel(company_file)).reset_index(drop=True)
    opportunities = normalize_opp_cols(pd.read_excel(opp_file)).reset_index(drop=True)

    comp_id_col = find_id_column(companies, "company")
    opp_id_col  = find_id_column(opportunities, "opportunity")
    companies["_company_id"] = (pd.to_numeric(companies[comp_id_col], errors="coerce").fillna(0).astype(int)
                                if comp_id_col else (companies.index + 1).astype(int))
    opportunities["_opp_id"] = (pd.to_numeric(opportunities[opp_id_col], errors="coerce").fillna(0).astype(int)
                                if opp_id_col else (opportunities.index + 1).astype(int))

    companies["_key"]     = companies.index.map(lambda i: f"C{i}")
    opportunities["_key"] = opportunities.index.map(lambda i: f"O{i}")

    print(f"Loaded {len(companies)} companies x {len(opportunities)} opportunities = "
          f"{len(companies)*len(opportunities)} candidate pairs")

    # ── STEP 1 — Preprocessing ────────────────────────────────────────────────
    print("\n[Step 1/8] Preprocessing — normalizing text...")
    companies["_profile_text"] = companies["company_profile"].astype(str).map(preprocess)
    companies["_sector_norm"]  = companies["Sector"].astype(str).map(canonicalize_sector)
    opportunities["_desc_text"]   = opportunities["What is the opportunity description?"].astype(str).map(preprocess)
    opportunities["_sector_norm"] = opportunities["Sector"].astype(str).map(canonicalize_sector)

    # Build rich combined documents — name + sector + profile + products
    def comp_combined(row) -> str:
        return preprocess(" ".join([
            safe_str(row["company_name"]), safe_str(row["Sector"]),
            safe_str(row["company_profile"]), safe_str(row["product_services"]),
        ]))

    def opp_combined(row) -> str:
        return preprocess(" ".join([
            safe_str(row["What is the opportunity name?"]), safe_str(row["Sector"]),
            safe_str(row["What is the opportunity description?"]),
            safe_str(row.get("What are the investment highlights?", "")),
            safe_str(row.get("What is the value proposition of this opportunity?", "")),
            safe_str(row.get("What are the key demand drivers?", "")),
            safe_str(row.get("What materials are involved or required in the project?", "")),
        ]))

    companies["_combined_text"]    = companies.apply(comp_combined, axis=1)
    opportunities["_combined_text"] = opportunities.apply(opp_combined, axis=1)

    # ── STEP 2 — Sector Ontology Expansion ────────────────────────────────────
    print("[Step 2/8] Sector ontology expansion...")
    all_sectors = list(set(
        companies["Sector"].astype(str).map(safe_str).tolist()
        + opportunities["Sector"].astype(str).map(safe_str).tolist()
    ))
    expanded = build_ontology(client, all_sectors, ONTOLOGY_CACHE_FILE)
    print(f"  Ontology built for {len(expanded)} unique sectors")

    # ── ENTITY EXTRACTION (feeds product_similarity) ──────────────────────────
    print("[Step 4a/8] Extracting product/capability entities...")
    opp_items = [{
        "id": row["_key"],
        "name": safe_str(row["What is the opportunity name?"]),
        "sector": safe_str(row["Sector"]),
        "description": safe_str(row["What is the opportunity description?"]),
        "highlights": safe_str(row.get("What are the investment highlights?", "")),
        "value_prop": safe_str(row.get("What is the value proposition of this opportunity?", "")),
        "demand": safe_str(row.get("What are the key demand drivers?", "")),
        "materials": safe_str(row.get("What materials are involved or required in the project?", "")),
    } for _, row in opportunities.iterrows()]

    opp_ent_text: Dict[str, str] = {}
    opp_ent_raw:  Dict[str, dict] = {}
    for i in tqdm(range(0, len(opp_items), EXTRACT_BATCH), desc="  Opp entities"):
        batch = opp_items[i: i + EXTRACT_BATCH]
        try:
            resp = extract_batch(client, batch, "opportunity")
        except Exception as e:
            print(f"    failed batch {i}: {e}"); resp = {}
        for b in batch:
            r = resp.get(b["id"], {})
            opp_ent_raw[b["id"]] = r
            opp_ent_text[b["id"]] = opp_entity_text(r)

    comp_items = [{
        "id": row["_key"], "company_name": safe_str(row["company_name"]),
        "sector": safe_str(row["Sector"]), "profile": safe_str(row["company_profile"]),
        "product_services": safe_str(row["product_services"]),
    } for _, row in companies.iterrows()]

    comp_ent_text: Dict[str, str] = {}
    comp_ent_raw:  Dict[str, dict] = {}
    for i in tqdm(range(0, len(comp_items), EXTRACT_BATCH), desc="  Company entities"):
        batch = comp_items[i: i + EXTRACT_BATCH]
        try:
            resp = extract_batch(client, batch, "company")
        except Exception as e:
            print(f"    failed batch {i}: {e}"); resp = {}
        for b in batch:
            r = resp.get(b["id"], {})
            comp_ent_raw[b["id"]] = r
            comp_ent_text[b["id"]] = comp_entity_text(r)

    companies["_product_text"]     = companies["_key"].map(comp_ent_text)
    opportunities["_product_text"] = opportunities["_key"].map(opp_ent_text)

    # ── STEP 4 — Dense embeddings (text-embedding-3-large) + sparse TF-IDF ───
    print(f"[Step 4/8] Building dense embeddings ({EMBEDDING_MODEL}) + sparse TF-IDF...")
    use_openai = True
    try:
        companies["emb_profile"]     = embed_batch(client, companies["_profile_text"].tolist(), EMBEDDING_MODEL)
        companies["emb_product"]     = embed_batch(client, companies["_product_text"].tolist(), EMBEDDING_MODEL)
        opportunities["emb_desc"]    = embed_batch(client, opportunities["_desc_text"].tolist(), EMBEDDING_MODEL)
        opportunities["emb_product"] = embed_batch(client, opportunities["_product_text"].tolist(), EMBEDDING_MODEL)
    except Exception as e:
        print(f"  Dense embeddings failed ({e}). Falling back to TF-IDF only.")
        use_openai = False
        all_texts = (
            companies["_profile_text"].tolist() + companies["_product_text"].tolist()
            + opportunities["_desc_text"].tolist() + opportunities["_product_text"].tolist()
        )
        tfidf_dense = TfidfVectorizer(ngram_range=(1, 2), min_df=1)
        tfidf_dense.fit(all_texts)
        companies["emb_profile"]     = list(tfidf_dense.transform(companies["_profile_text"]).toarray())
        companies["emb_product"]     = list(tfidf_dense.transform(companies["_product_text"]).toarray())
        opportunities["emb_desc"]    = list(tfidf_dense.transform(opportunities["_desc_text"]).toarray())
        opportunities["emb_product"] = list(tfidf_dense.transform(opportunities["_product_text"]).toarray())

    # Sparse TF-IDF on combined-document text — captures exact product / segment names
    sparse_corpus = companies["_combined_text"].tolist() + opportunities["_combined_text"].tolist()
    tfidf_sparse = TfidfVectorizer(ngram_range=(1, 2), min_df=1, max_df=0.95, sublinear_tf=True)
    tfidf_sparse.fit(sparse_corpus)
    comp_sparse_mat = tfidf_sparse.transform(companies["_combined_text"])
    opp_sparse_mat  = tfidf_sparse.transform(opportunities["_combined_text"])

    # ── STEPS 3 + 5 + 7 — candidate matrix with sector + sparse + soft match ──
    print("[Steps 3+5+7/8] Sector overlap + product matching + soft-match labelling...")
    rows: List[dict] = []
    n_sector  = 0; n_soft = 0; n_weak = 0

    # Pre-compute sparse similarity matrix (companies x opportunities)
    sparse_sim_matrix = cosine_similarity(comp_sparse_mat, opp_sparse_mat)

    for opp_idx, opp in opportunities.iterrows():
        opp_sector_raw = safe_str(opp["Sector"])
        opp_name       = safe_str(opp["What is the opportunity name?"])
        for comp_idx, comp in companies.iterrows():
            comp_sector_raw = safe_str(comp["Sector"])
            comp_name       = safe_str(comp["company_name"])

            profile_sim = round(safe_cos(comp["emb_profile"], opp["emb_desc"]), 3)
            product_sim = round(safe_cos(comp["emb_product"], opp["emb_product"]), 3)
            sparse_sim  = round(float(sparse_sim_matrix[comp_idx, opp_idx]), 3)
            combined    = max(profile_sim, product_sim, sparse_sim)

            sector_sim_literal = 1 if (comp["_sector_norm"] and opp["_sector_norm"]
                                       and comp["_sector_norm"] == opp["_sector_norm"]) else 0
            sector_overlap = sectors_overlap(comp_sector_raw, opp_sector_raw, expanded)

            if sector_overlap:
                pass_reason = "sector_overlap"; n_sector += 1
            elif combined >= SOFT_MATCH_THRESHOLD:
                pass_reason = "soft_match"; n_soft += 1
            else:
                pass_reason = "weak_overlap"; n_weak += 1

            rows.append({
                "_pair_key":    f"{opp['_key']}_{comp['_key']}",
                "_opp_key":     opp["_key"],
                "_comp_key":    comp["_key"],
                "_pass_reason": pass_reason,
                "_combined":    float(combined),
                "companyId":     int(comp["_company_id"]),
                "opportunityId": int(opp["_opp_id"]),
                "company_name":      comp_name,
                "opportunity_name":  opp_name,
                "company_sector":     comp_sector_raw,
                "opportunity_sector": opp_sector_raw,
                "sector_similarity":  int(sector_sim_literal),
                "profile_similarity": float(profile_sim),
                "product_similarity": float(product_sim),
                "sparse_score":       float(sparse_sim),
                "ai_score":         0,
                "ai_decision":      "",
                "match_value":      0,
                "match_confidence": "",
                "ai_explanation":   "",
                "ai_insight":       "",
                "suggested_plan":   [],
                "match_reason":     [],
            })

    df = pd.DataFrame(rows)
    print(f"  Match paths — sector overlap: {n_sector}, soft-match: {n_soft}, weak: {n_weak}")
    print(f"  Sending all {len(df)} pairs to GPT for analyst-grade evaluation.")

    # ── STEP 6 — GPT validation on EVERY pair ────────────────────────────────
    print("[Step 6/8] GPT validation (Yes/No + match_value + analyst narrative)...")
    for opp_key, group in tqdm(df.groupby("_opp_key"), total=df["_opp_key"].nunique()):
        opp = opportunities[opportunities["_key"] == opp_key].iloc[0]
        oent = opp_ent_raw.get(opp_key, {})

        opp_context = {
            "opportunity_name":        safe_str(opp["What is the opportunity name?"]),
            "opportunity_sector":      safe_str(opp["Sector"]),
            "opportunity_description": safe_str(opp["What is the opportunity description?"]),
            "investment_highlights":   safe_str(opp.get("What are the investment highlights?", "")),
            "value_proposition":       safe_str(opp.get("What is the value proposition of this opportunity?", "")),
            "demand_drivers":          safe_str(opp.get("What are the key demand drivers?", "")),
            "materials":               safe_str(opp.get("What materials are involved or required in the project?", "")),
            "required_products":     to_list(oent.get("required_products")),
            "required_services":     to_list(oent.get("required_services")),
            "required_materials":    to_list(oent.get("required_materials")),
            "required_capabilities": to_list(oent.get("required_capabilities")),
        }

        idxs = group.index.tolist()
        for i in range(0, len(idxs), DECISION_BATCH):
            bidx = idxs[i: i + DECISION_BATCH]
            candidates = []
            for idx in bidx:
                comp_key = df.at[idx, "_comp_key"]
                comp     = companies[companies["_key"] == comp_key].iloc[0]
                cent     = comp_ent_raw.get(comp_key, {})
                pass_reason = df.at[idx, "_pass_reason"]
                match_path = {
                    "sector_overlap": "Direct sector match (sector ontology overlap)",
                    "soft_match":     "Cross-sector adjacency — Soft Match Mode (combined semantic >= 0.85)",
                    "weak_overlap":   "Weak overlap — neither sector match nor strong semantic (likely No)",
                }[pass_reason]
                candidates.append({
                    "candidate_id":    df.at[idx, "_pair_key"],
                    "company_name":    safe_str(comp["company_name"]),
                    "company_sector":  safe_str(comp["Sector"]),
                    "company_profile": safe_str(comp["company_profile"]),
                    "product_services": safe_str(comp["product_services"]),
                    "actual_products":  to_list(cent.get("actual_products")),
                    "actual_services":  to_list(cent.get("actual_services")),
                    "capabilities":     to_list(cent.get("capabilities")),
                    "match_path":       match_path,
                    "ranking_signals": {
                        "sector_similarity":  int(df.at[idx, "sector_similarity"]),
                        "profile_similarity": float(df.at[idx, "profile_similarity"]),
                        "product_similarity": float(df.at[idx, "product_similarity"]),
                        "sparse_score":       float(df.at[idx, "sparse_score"]),
                        "combined_max":       float(df.at[idx, "_combined"]),
                    },
                })

            try:
                results_map = gpt_decide_batch(client, opp_context, candidates)
            except Exception as e:
                print(f"  GPT decision failed for {opp_key} batch {i}: {e}")
                results_map = {}

            for idx in bidx:
                cid = df.at[idx, "_pair_key"]
                raw = results_map.get(cid, {"candidate_id": cid, "ai_decision": "No"})
                r   = safe_decision(raw, cid)

                df.at[idx, "ai_decision"]      = r["ai_decision"]
                df.at[idx, "ai_score"]         = 1 if r["ai_decision"] == "Yes" else 0
                df.at[idx, "match_value"]      = r["match_value"]
                df.at[idx, "match_confidence"] = r["match_confidence"]
                df.at[idx, "ai_explanation"]   = r["ai_explanation"]
                df.at[idx, "ai_insight"]       = r["ai_insight"]
                df.at[idx, "suggested_plan"]   = r["suggested_plan"]
                df.at[idx, "match_reason"]     = r["match_reason"]

    # ── STEP 8 — Final Score & Rank ───────────────────────────────────────────
    print("[Step 8/8] Final score and ranking...")
    df["final_score"] = (
        W_AI      * df["ai_score"].astype(float)
        + W_PROFILE * df["profile_similarity"].astype(float)
        + W_PRODUCT * df["product_similarity"].astype(float)
    ).round(3)

    # Rank by combination of GPT match_value (primary) and final_score (tiebreak)
    df = df.sort_values(
        by=["opportunityId", "match_value", "final_score"],
        ascending=[True, False, False],
    ).reset_index(drop=True)
    df["rank"] = df.groupby("opportunityId").cumcount() + 1

    df = df.sort_values(by=["companyId", "rank"]).reset_index(drop=True)
    df.insert(0, "id", range(1, len(df) + 1))

    # ── OUTPUT ────────────────────────────────────────────────────────────────
    df["suggested_plan_str"] = df["suggested_plan"].apply(lambda xs: json.dumps(xs, ensure_ascii=False))
    df["match_reason_str"]   = df["match_reason"].apply(lambda xs: json.dumps(xs, ensure_ascii=False))

    out = pd.DataFrame({
        "id":                  df["id"].astype(int),
        "companyId":           df["companyId"].astype(int),
        "opportunityId":       df["opportunityId"].astype(int),
        "company_name":        df["company_name"],
        "opportunity_name":    df["opportunity_name"],
        "company_sector":      df["company_sector"],
        "opportunity_sector":  df["opportunity_sector"],
        "sector_similarity":   df["sector_similarity"].astype(int),
        "profile_similarity":  df["profile_similarity"].astype(float).round(3),
        "product_similarity":  df["product_similarity"].astype(float).round(3),
        "sparse_score":        df["sparse_score"].astype(float).round(3),
        "ai_score":            df["ai_score"].astype(int),
        "ai_decision":         df["ai_decision"],
        "match_value":         df["match_value"].astype(int),
        "match_confidence":    df["match_confidence"],
        "final_score":         df["final_score"].astype(float).round(3),
        "ai_explanation":      df["ai_explanation"],
        "rank":                df["rank"].astype(int),
        "ai_insight":          df["ai_insight"],
        "suggested_plan":      df["suggested_plan_str"],
        "match_reason":        df["match_reason_str"],
    })

    os.makedirs(os.path.dirname(OUTPUT_FILE), exist_ok=True)
    out.to_excel(OUTPUT_FILE, index=False)

    # Excel formatting
    try:
        from openpyxl import load_workbook
        from openpyxl.styles import Alignment, Font, PatternFill
        from openpyxl.utils import get_column_letter
        wb = load_workbook(OUTPUT_FILE)
        ws = wb.active
        headers = [ws.cell(row=1, column=i).value for i in range(1, ws.max_column + 1)]
        header_fill = PatternFill(start_color="1F2937", end_color="1F2937", fill_type="solid")
        header_font = Font(color="FFFFFF", bold=True)
        for c in range(1, ws.max_column + 1):
            cell = ws.cell(row=1, column=c)
            cell.fill = header_fill
            cell.font = header_font
            cell.alignment = Alignment(horizontal="left", vertical="center", wrap_text=True)
        narrative = {"ai_explanation", "ai_insight", "suggested_plan", "match_reason"}
        widths = {
            "id": 6, "companyId": 10, "opportunityId": 12,
            "company_name": 28, "opportunity_name": 32,
            "company_sector": 18, "opportunity_sector": 18,
            "sector_similarity": 10, "profile_similarity": 10, "product_similarity": 10,
            "sparse_score": 10, "ai_score": 8, "ai_decision": 12,
            "match_value": 11, "match_confidence": 13, "final_score": 11,
            "ai_explanation": 70, "rank": 6, "ai_insight": 60,
            "suggested_plan": 60, "match_reason": 60,
        }
        for c, name in enumerate(headers, 1):
            ws.column_dimensions[get_column_letter(c)].width = widths.get(name, 16)
            if name in narrative:
                for r in range(2, ws.max_row + 1):
                    ws.cell(row=r, column=c).alignment = Alignment(wrap_text=True, vertical="top")

        # Color band ai_decision
        if "ai_decision" in headers:
            dec_col = headers.index("ai_decision") + 1
            yes_fill = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")
            no_fill  = PatternFill(start_color="FFC7CE", end_color="FFC7CE", fill_type="solid")
            for r in range(2, ws.max_row + 1):
                v = ws.cell(row=r, column=dec_col).value
                if v == "Yes":
                    ws.cell(row=r, column=dec_col).fill = yes_fill
                elif v == "No":
                    ws.cell(row=r, column=dec_col).fill = no_fill

        # Color-band match_value: gradient from red (<40) → yellow (40-70) → green (>70)
        if "match_value" in headers:
            mv_col = headers.index("match_value") + 1
            green = PatternFill(start_color="A9D08E", end_color="A9D08E", fill_type="solid")
            yel   = PatternFill(start_color="FFD966", end_color="FFD966", fill_type="solid")
            red   = PatternFill(start_color="F4B084", end_color="F4B084", fill_type="solid")
            for r in range(2, ws.max_row + 1):
                v = ws.cell(row=r, column=mv_col).value
                try:
                    iv = int(v)
                    if iv >= 70: ws.cell(row=r, column=mv_col).fill = green
                    elif iv >= 40: ws.cell(row=r, column=mv_col).fill = yel
                    else: ws.cell(row=r, column=mv_col).fill = red
                except Exception:
                    pass

        ws.freeze_panes = "A2"
        wb.save(OUTPUT_FILE)
    except Exception as e:
        print(f"  (Excel formatting skipped: {e})")

    # ── SUMMARY ───────────────────────────────────────────────────────────────
    print(f"\nOutput saved : {OUTPUT_FILE}")
    print(f"Total rows   : {len(out)}")
    print(f"\nai_decision breakdown:")
    for d, cnt in out["ai_decision"].value_counts().items():
        print(f"  {d:<5} {cnt}")

    yes_cross = ((out["ai_decision"] == "Yes") & (out["sector_similarity"] == 0)).sum()
    yes_in    = ((out["ai_decision"] == "Yes") & (out["sector_similarity"] == 1)).sum()
    print(f"\nYes matches: {yes_in} in-sector + {yes_cross} cross-sector (Soft Match Mode)")

    print(f"\nmatch_value distribution:")
    for tier, lo, hi in [("Exceptional (90+)", 90, 101), ("Strong (75-89)", 75, 90),
                          ("Moderate (60-74)", 60, 75), ("Weak (40-59)", 40, 60),
                          ("Poor (20-39)", 20, 40), ("No fit (<20)", 0, 20)]:
        n = ((out["match_value"] >= lo) & (out["match_value"] < hi)).sum()
        print(f"  {tier:<22} {n}")

    print(f"\nmatch_confidence:")
    for c, cnt in out["match_confidence"].value_counts().items():
        print(f"  {c:<8} {cnt}")


if __name__ == "__main__":
    main()
